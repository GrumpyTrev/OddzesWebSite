@{
    Layout = "~/Trips/_TripsLayout.cshtml";

    StarterSiteEntities model = new StarterSiteEntities();

    int transactionId = UrlData[0].AsInt();

    Transaction transactionToDisplay = model.Transactions.SingleOrDefault(trans => trans.Id == transactionId);

    Page.Title = transactionToDisplay.Title;

    // If this is a POST request, validate and process data
    if ( IsPost == true )
    {
        // Delete this transaction and any associated sharers
        model.Sharers.RemoveRange(model.Sharers.Where(sharer => sharer.TransactionId == transactionToDisplay.Id));
        model.Transactions.Remove(transactionToDisplay);
        model.SaveChanges();

        // Return back to the trip
        Response.Redirect(Href("~/Trips/Trip", transactionToDisplay.TripId));
    }
}

@section featured {
    <section class="featured">
        <div class="content-wrapper">
            <hgroup class="title">
                <h1>@Page.Title.</h1>
            </hgroup>
            @if ( WebSecurity.IsAuthenticated == true )
            {
                <p>@transactionToDisplay.Date.ToString("dddd d MMMM yyyy")</p>
            }
            else
            {
                <p>Please login to display the transactions for this trip</p>
            }
        </div>
    </section>
}

@if ( WebSecurity.IsAuthenticated == true )
{
    if ( transactionToDisplay.IsBalance == false )
    {
        <table>

            <tr><td><strong>Paid by</strong></td></tr>
            <tr>
                <td style="padding-left:10px;"><strong>@HelperMethods.UserNameString(transactionToDisplay.WhoId)</strong></td>
                <td style="padding-left:10px;"><strong>@HelperMethods.AmountString(transactionToDisplay.LocalValue, transactionToDisplay.CurrencyId)</strong></td>
            </tr>
            <tr><td><strong>Shared By</strong></td> </tr>

            @{
                List<string> participants = HelperMethods.OrderedTripParticipants(transactionToDisplay.TripId);
                foreach ( string userName in participants )
                {
                    <tr>
                        <td style="padding-left:10px;"><strong>@userName</strong></td>
                        <td style="padding-left:10px;"><strong>@HelperMethods.AmountString(transactionToDisplay.LocalValue / participants.Count, transactionToDisplay.CurrencyId)</strong></td>
                    </tr>
                }
            }
        </table>
    }
    else
    {
        <p>
            <strong>@HelperMethods.AmountString(transactionToDisplay.LocalValue, transactionToDisplay.CurrencyId)</strong>
            from <strong>@HelperMethods.UserNameString(transactionToDisplay.WhoId)</strong>
            to <strong>@HelperMethods.UserNameString(transactionToDisplay.PaidToId)</strong>
        </p>
    }

    <p></p>
    <form method="post">
        @{
            if ( transactionToDisplay.IsBalance == false )
            {
                <a href="@Href("~/Trips/EditTransaction", transactionId)" class="btn">Edit</a>
                <input type="submit" value="Delete" id="submit" onclick="return confirm( 'Are you sure you want to delete this transaction?');">
            }
            else
            {
                <a href="@Href("~/Trips/EditPayment", transactionId)" class="btn">Edit</a>
                <input type="submit" value="Delete" id="submit" onclick="return confirm( 'Are you sure you want to delete this payment?');">
            }
        }
    </form>
}
